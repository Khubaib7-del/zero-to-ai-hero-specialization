ipython_config.py

# pyenv
#   For a library or package, you might want to ignore these files since the code is
#   intended to run in multiple environments; otherwise, check them in:
# .python-version

# pipenv
#   According to pypa/pipenv#1255, pipenv should generally check in Pipfile.lock.
#   For apps, check Pipfile.lock into source control; for libraries, ignore it.
# Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock can be ignored or checked in.
# poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock can be ignored or checked in.
# pdm.lock

# PEP 582; project local packages directory (used by pdm)
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

